#!/bin/sh
#####################################################################
# Author    : Erik Dubois
# Website   : https://kiroproject.be
#####################################################################
#   DO NOT JUST RUN THIS. EXAMINE AND JUDGE. RUN AT YOUR OWN RISK.
#
# Purpose:
#   Session entrypoint for the Kiro Hyprland (noctalia) edition, invoked by
#   kiro-hyprland-noctalia.desktop. Launches Hyprland pointed at this edition's
#   own config folder (~/.config/kiro-hyprland-noctalia/hyprland.lua) via the
#   --config flag, so it never reads ~/.config/hypr/.
# Why:
#   kiro-hyprland-noctalia and the waybar-based kiro-hyprland edition both target
#   Hyprland but ship different configs. Sharing ~/.config/hypr/ means switching
#   editions inherits the other one's stale config. Pointing Hyprland at a
#   per-edition config folder keeps them cleanly separate and co-installable.
#   Hyprland is started directly (no systemd service like niri), so a plain
#   --config flag is all that is needed — no NIRI_CONFIG-style env dance.
#####################################################################

exec Hyprland --config "$HOME/.config/kiro-hyprland-noctalia/hyprland.lua" "$@"
